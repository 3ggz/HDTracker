# Copy this file to `.env.local` and fill in real values.
# .env.local is gitignored — never commit it.

# Supabase — find these in your Supabase project under
# Project Settings > API Keys.

# The publishable key (sb_publishable_*) is safe to expose in browser code;
# Row Level Security policies are what protect your data.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-key-here

# The service role key (sb_secret_* / a JWT in legacy projects) bypasses
# RLS and grants full auth-admin access. Used only by server actions for
# privileged operations like the admin "Delete account" flow. NEVER prefix
# this with NEXT_PUBLIC_ and never include it in client code — the
# `import "server-only"` guard in src/lib/supabase/admin.ts is the
# build-time backstop.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_your-service-role-key-here
